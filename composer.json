{
    "name": "well35/laravel-enum-objects",
    "description": "Generate frontend enum objects from PHP enums, so backend enums are the single source of truth for values and metadata.",
    "license": "MIT",
    "type": "library",
    "keywords": ["laravel", "enum", "typescript", "codegen", "frontend"],
    "authors": [
        { "name": "well35", "role": "Maintainer" },
        { "name": "IronSinew", "role": "Original concept" }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "Well35\\EnumObjects\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Well35\\EnumObjects\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Well35\\EnumObjects\\EnumObjectsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}
